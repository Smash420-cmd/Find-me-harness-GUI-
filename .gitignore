# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build output
/dist

# runtime logs
server.log
server.err

# generated screenshots — audit evidence IS committed, the rest is disposable
screenshots/*
!screenshots/audit/

# frozen worlds (Spec 006) — recorded snapshots are large; commit deliberately, not by default
worlds/
!worlds/*/manifest.json
